# Copy this file to .env and fill in your real values
# Never commit .env to GitHub!

# IBM Watson Speech to Text
STT_API_KEY=paste_your_stt_api_key_here
STT_URL=paste_your_stt_service_url_here

# IBM Watson Natural Language Understanding
NLU_API_KEY=paste_your_nlu_api_key_here
NLU_URL=paste_your_nlu_service_url_here

# Gmail sender (optional — only needed for email feature)
# Use a Gmail App Password, NOT your real Gmail password
# Get one at: myaccount.google.com/apppasswords
SENDER_EMAIL=youremail@gmail.com
SENDER_PASSWORD=your_16_char_app_password

# Port (Render/Railway set this automatically)
PORT=5000